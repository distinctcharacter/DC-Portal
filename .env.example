# Distinct Character Protocol Portal
# Backend-ready environment template
# Do not place live secrets in source control.

# Site
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_PORTAL_URL=http://localhost:3000
NEXT_PUBLIC_MARKETING_SITE_URL=https://distinctcharacter.com

# Supabase public browser values
NEXT_PUBLIC_SUPABASE_URL=replace_with_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=replace_with_supabase_anon_key

# Supabase server-only values
SUPABASE_SERVICE_ROLE_KEY=replace_with_supabase_service_role_key
SUPABASE_DB_PASSWORD=replace_with_saved_database_password

# Stripe public browser value
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=replace_with_stripe_publishable_key

# Stripe server-only values
STRIPE_SECRET_KEY=replace_with_stripe_secret_key
STRIPE_WEBHOOK_SECRET=replace_with_stripe_webhook_signing_secret
STRIPE_WEBHOOK_TOLERANCE_SECONDS=300

# Stripe existing product and price mappings
# Product-to-access rules live in the database table:
# stripe_product_mappings
# Do not duplicate product mapping rules in environment variables.

# Auth behavior
AUTH_ENABLE_PASSWORD=true
AUTH_ENABLE_MAGIC_LINK=true
AUTH_ENABLE_SOCIAL_LOGIN=false

# Email redirects
AUTH_REDIRECT_URL=http://localhost:3000/auth/callback
POST_PURCHASE_CLAIM_URL=http://localhost:3000/access/claim

# Storage
SUPABASE_STORAGE_PROTOCOL_BUCKET=protocol-assets
SUPABASE_STORAGE_RESOURCE_BUCKET=resource-library
SUPABASE_STORAGE_PRACTITIONER_BUCKET=practitioner-assets
SUPABASE_STORAGE_LICENSE_BUCKET=license-holder-assets
